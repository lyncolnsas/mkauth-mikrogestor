ar o controle de pools aqui.' . PHP_EOL . '</div>' . PHP_EOL . '<div class="columns is-multiline">' . PHP_EOL . '<div class="column is-10">' . PHP_EOL . '<div id="run_valid">' . PHP_EOL . '<form name="form_valid" id="form_valid" method="POST" action="executar_pool.hhvm?acao=ins.pool">' . PHP_EOL . '<h4 class="subtitle is-7 has-text-weight-bold has-text-grey"> Inserir pool </h4>' . PHP_EOL . '<div class="block">' . PHP_EOL . '<div class="field is-horizontal">' . PHP_EOL . '<div class="field-label is-size-7">' . PHP_EOL . '<label class="label"> Nome: </label>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<input class="input" name="nome" id="nome_valid" type="text" placeholder="Nome do pool" maxlength="30" df_verificar="sim" />' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="block" id="ranges-input">' . PHP_EOL . '<div class="block">' . PHP_EOL . '<div class="field is-horizontal">' . PHP_EOL . '<div class="field-label is-size-7">' . PHP_EOL . '<label class="label"> Range: </label>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field has-addons">' . PHP_EOL . '<div class="control">' . PHP_EOL . '<button class="button is-danger" type="button" onClick="delRange(this)">' . PHP_EOL . '<i class="bi-dash"></i>' . PHP_EOL . '</button>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<input class="input" name="range[]" id="range" type="text" placeholder="0.0.0.0-0.0.0.0" maxlength="32">' . PHP_EOL . '</div>' . PHP_EOL . '<div class="control">' . PHP_EOL . '<button class="button is-info" type="button" onClick="newRange(this)">' . PHP_EOL . '<i class="bi-plus"></i>' . PHP_EOL . '</button>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP