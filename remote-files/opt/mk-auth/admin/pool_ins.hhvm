. PHP_EOL . '	jQuery(\'#msg_conf_final\').html(\'<span class="is-size-6 has-text-info">Rede de classe /\' + mask_valido + \'</span>\');' . PHP_EOL . '	if (valida_ipv4(ip_valido) == true) {' . PHP_EOL . '		ip_valido = ip2long(ip_valido);' . PHP_EOL . '		ip_network = ip_valido - 1;' . PHP_EOL . '		ip_broadcast = ip_network + (ips_somar[mask_valido] - 1);' . PHP_EOL . '		ip_final = ip_broadcast - 1;' . PHP_EOL . '		ip_network = long2ip(ip_network);' . PHP_EOL . '		ip_final = long2ip(ip_final);' . PHP_EOL . '		ip_broadcast = long2ip(ip_broadcast);' . PHP_EOL . '		jQuery("#ip_final").val(ip_final);' . PHP_EOL . '		jQuery("#msg_ip_final").html(ip_final);' . PHP_EOL . '		jQuery("#network_broadcast").html(ip_network + \'/\' + ip_broadcast);' . PHP_EOL . '	} else {' . PHP_EOL . '		jQuery(\'#msg_conf_final\').html(\'<span class="is-size-6 has-text-danger">Endereco ip invalido.</span>\');' . PHP_EOL . '		return false;' . PHP_EOL . '	}	' . PHP_EOL . '};' . PHP_EOL . 'jQuery("#range_cgnat").change(function() {' . PHP_EOL . '	jQuery(\'#btn_gravar_cgnat\').attr(\'disabled\', true);' . PHP_EOL . '	cgnat_range = jQuery("#range_cgnat").val();' . PHP_EOL . '	cgnat_range = cgnat_range.split(\'-\');' . PHP_EOL . '	total_range = totalRange(cgnat_range[0],cgnat_range[1]);' . PHP_EOL . '	if (total_range) {' . PHP_EOL . '		jQuery("#total_range").val(total_range);' . PHP_EOL . '		jQuery(\'#msg_total_range\').html(\'<span class="is-size-6 has-text-info">Range com \' + total_range + \' hosts no total.</span>\');' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#ip_valido").change(function() {' . PHP_EOL . '	ip_valido = jQuery("#ip_valido").val();' . PHP_EOL . '	mask_valido = jQuery("#mask_valido").val();' . PHP_EOL . '	jQuery(\'#btn_gravar_cgnat\').attr(\'disabled\', true);' . PHP_EOL . '	gen_ip_final(ip_valido, mask_valido);' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#mask_valido").change(function() {' . PHP_EOL . '	ip_valido = jQuery("#ip_valido").val();' . PHP_EOL . '	mask_valido = jQu