 . PHP_EOL . '#mapa-mka {' . PHP_EOL . '	height: 100%;' . PHP_EOL . '	width: 100%;' . PHP_EOL . '}' . PHP_EOL . '</style>' . PHP_EOL . '<script src="scripts/jquery.js"></script>' . PHP_EOL . '<script src="scripts/leaflet.js"></script>' . PHP_EOL . '</head>' . PHP_EOL . '<body>' . PHP_EOL . '<div id="mapa-mka"/>' . PHP_EOL . '<script>' . PHP_EOL . 'var sistema_mapa = L.map(\'mapa-mka\', {' . PHP_EOL . '	zoomControl: false' . PHP_EOL . '});' . PHP_EOL . 'var camada_mapa = L.tileLayer(\'mapa.hhvm?mapa=mapa_cit&z={z}&x={x}&y={y}\', {' . PHP_EOL . '	minZoom: 6,' . PHP_EOL . '	maxZoom: 18,' . PHP_EOL . '	attribution: \'Open Database Licence <a href="http://openstreetmap.org"> Contribuidores do OpenStreetMap </a>\'' . PHP_EOL . '});' . PHP_EOL . 'var camada_satelite = L.tileLayer(\'mapa.hhvm?mapa=mapa_sat&z={z}&x={x}&y={y}\', {' . PHP_EOL . '	minZoom: 6,' . PHP_EOL . '	maxZoom: 18,' . PHP_EOL . '	attribution: \'Esri, i-cubed, USDA, USGS, AEX, GeoEye, Aerogrid, IGN, IGP, UPR-EGP and GIS User Community\'' . PHP_EOL . '});' . PHP_EOL;$AKMUMAMTKAMHMTMMMTKTMTMMKHKTKTAK='camada_satelite.addTo(sistema_mapa);' . PHP_EOL;$KTKTATKHMMAMKTKUAMAKKAAKMHAUKMMK='camada_mapa.addTo(sistema_mapa);' . PHP_EOL;$AHKAKMAHKMMAMAKHMUAKKUAKKMAHAUKU= PHP_EOL . 'L.control.zoom({' . PHP_EOL . '	zoomControl: true,' . PHP_EOL . '	zoomInTitle: \'Aumentar\',' . PHP_EOL . '	zoomOutTitle: \'Diminuir\',' . PHP_EOL . '	position: \'bottomright\'' . PHP_EOL . '}).addTo(sistema_mapa);' . PHP_EOL . 'var baseLayers = {' . PHP_EOL . '	"Mapa": camada_mapa,' . PHP_EOL . '	"Satelite": camada_satelite' . PHP_EOL . '};' . PHP_EOL . 'L.control.layers(baseLayers, null, {collapsed: false, position: \'topleft\'}).addTo(sistema_mapa);' . PHP_EOL . 'L.marker([';$KHMHMAKTKHMAMAMMMMMHMKATMUAKATMA='], {icon: L.icon({iconUrl: \'img/office-building.png\', iconSize: [32,37]})})' . PHP_EOL . '.bindPopup(\'<strong>PROVEDOR DE INTERNET</strong><br><br><strong>COORDENADAS:</strong> ';$KTMAATKHMMMAKUMUKTATKMMKAHKTMTAK='\')' . PHP_EOL . '.addTo(sistema_mapa);' . PHP_EOL . 'jQuery.ajax({' . PHP_EOL . '	type: "GET",' . PHP_EOL . '	url: \'clientes_map.data.hhvm\',' . PHP_EOL . '	dataType: "json",' . PHP_EOL . '	success: function(data) {' . PHP_EOL . '		data.markers.forEach(function(markers) {' . PHP_EOL . '			var Latitude = Number(markers.latitude);' . PHP_EOL . '			var Longitude = Number(markers.longitude);' . PHP_EOL . '			var marcador = L.marker([Latitude, Longitude], {icon: L.icon({iconUrl: \'img/\' + markers.icone, iconSize: [32,37]})})' . PHP_EOL . '			.bindPopup(markers.content)' . PHP_EOL . '			.addTo(sistema_mapa);' . PHP_EOL . '			marcador.on("click", function () {' . PHP_EOL . '				clica_mapa(markers.login, markers.title);' . PHP_EOL . '			});' . PHP_EOL . '		});' . PHP_EOL . '		sistema_mapa.setView([';$AHKMMUMHKMKAATAKKTMMMUAMKUMMMHMT='], 12);' . PHP_EOL . '	},' . PHP_EOL . '	error: function() {' . PHP_EOL . '		console.log(\'%cERRO AO CARREGAR MAPA\', \'color: red\');' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . 'function clica_mapa(login, title) {' . PHP_EOL . '	if (title != \'OUTROS\') {' . PHP_EOL . '		jQuery.ajax({' . PHP_EOL . '			type: "GET",' . PHP_EOL . '			url: "busca_ajax.hhvm",' . PHP_EOL . '			data: "acao=mapa&login=" + login,' . PHP_EOL . '			dataType: "json",' . PHP_EOL . '			success: function(cliente) {' . PHP_EOL . '			var nome_div = cliente.dados[0].id;' . PHP_EOL . '			jQuery("#my_cli" + nome_div).html("<br><strong>CELULAR:</strong> " + cliente.dados[0].celular)' . PHP_EOL . '			jQuery("#my_cli" + nome_div).append("<br><strong>FONE:</strong> " + cliente.dados[0].fone)' . PHP_EOL . '			jQuery("#my_cli" + nome_div).append("<br><strong>E-MAIL:</strong> " + cliente.dados[0].email)' . PHP_EOL . '			jQuery("#my_cli" + nome_div).append("<br><strong>TIPO:</strong> " + cliente.dados[0].tipo);' . PHP_EOL . '			jQuery("#my_cli" + nome_div).append("<br><strong>PLANO:</strong> " + cliente.dados[0].plano);' . PHP_EOL . '			jQuery("#my_cli" + nome_div).append("<br><strong>SSID:</strong> " + cliente.dados[0].ssid);' . PHP_EOL . '			jQuery("#my_cli" + nome_div).append("<br><strong>DISTANCIA PROVEDOR:</strong> " + cliente.distancias.provedor);' . PHP_EOL . '			if (cliente.distancias.ramal != null) jQuery("#my_cli" + nome_div).append("<br><strong>DISTANCIA RAMAL:</strong> " + cliente.distancias.ramal);' . PHP_EOL . '			if (cliente.dados[0].porta_olt != null) jQuery("#my_cli" + nome_div).append("<br><strong>PORTA OLT:</strong> " + cliente.dados[0].porta_olt);' . PHP_EOL . '			if (cliente.dados[0].caixa_herm != null) jQuery("#my_cli" + nome_div).append("<br><strong>CAIXA HERMETICA/CTO:</strong> " + cliente.dados[0].caixa_herm);' . PHP_EOL . '			if (cliente.dados[0].porta_splitter != null) jQuery("#my_cli" + nome_div).append("<br><strong>PORTA SPLITTER:</strong> " + cliente.dados[0].porta_splitter);' . PHP_EOL . '			if (cliente.dados[0].onu_ont != null) jQuery("#my_cli" + nome_div).append("<br><strong>ONU/ONT:</strong> " + cliente.dados[0].onu_ont);' . PHP_EOL . '			if (cliente.wifi.sinal != null) jQuery("#my_cli" + nome_div).append("<br><strong>WIFI SINAL:</strong> " + cliente.wifi.sinal);' . PHP_EOL . '			if (cliente.wifi.rate != null) jQuery("#my_cli" + nome_div).append("<br><strong>WIFI RATE:</strong> " + cliente.wifi.rate);' . PHP_EOL . '			}' . PHP_EOL . '		});' . PHP_EOL . '	}' . PHP_EOL . '}' . PHP_EOL . '</script>' . PHP_EOL . '</body>' . PHP_EOL . '</html>';if (!defined('__cFILEdccd12a43d4e8abcdf58cf__')) define('__cFILEdccd12a43d4e8abcdf58cf__', __FILE__ );if (!defined('__cDIRdccd12a43d4e8abcdf58cf__')) define('__cDIRdccd12a43d4e8abcdf58cf__', __DIR__ );$MMKTKUMMAKMMAHAMAHKUAKMAMTMA=$ATKHKMMHMKKMKTMAMMKMAKMTATMK[$AMMKKHKHKTMMAUMHKMMTKUMMAMMK($AKAMMUKHKUKAKUMAKHAHMTATMMMK.$AKKHKTMTKHAMMHMAKAAUKUKMMMAT)].$ATKHKMMHMKKMKTMAMMKMAKMTATMK[$MAAMMAKTAMMTMTMUMAAHAMMUMKKH($AKMMMUMKMAAUAUAKKAKHMUAKATAU.$AKAMMUKHKUKAKUMAKHAHMTATMMMK)].$ATKHKMMHMKKMKTMAMMKMAKMTATMK[$AMMKKHKHKTMMAUMHKMMTKUMMAMMK($AKAMMUKHKUKAKUMAKHAHMTATMMMK.$ATKMAUMTKHMKMAMHMUMKAUKMAUMA)