eight: 100%;' . PHP_EOL . '	width: 100%;' . PHP_EOL . '}' . PHP_EOL . '</style>' . PHP_EOL . '<!-- Carrega a API do Google Maps de forma assíncrona -->' . PHP_EOL . '<script async defer src="https://maps.googleapis.com/maps/api/js?key=';$MHMTAHAHAMMKAHMKMAMAKTMMMHMAAMAK='&callback=initMap"></script>' . PHP_EOL . '<script src="scripts/jquery.js"></script>' . PHP_EOL . '</head>' . PHP_EOL . '<body>' . PHP_EOL . '<div id="carregando" style="position: absolute"><img src="img/mkload.gif" /></div>' . PHP_EOL . '<div id="mapa-mka"></div>' . PHP_EOL . '<script>' . PHP_EOL . 'async function initMap() {' . PHP_EOL . '	// Inicializa o mapa com mapId' . PHP_EOL . '	const map = new google.maps.Map(document.getElementById("mapa-mka"), {' . PHP_EOL . '		mapId: "CLIENTES"' . PHP_EOL . '	});' . PHP_EOL . '	// Carrega as bibliotecas de marcadores' . PHP_EOL . '	const { AdvancedMarkerElement, PinElement } = await google.maps.importLibrary("marker");' . PHP_EOL . '	// Cria um objeto LatLngBounds para ajustar os limites do mapa' . PHP_EOL . '	const bounds = new google.maps.LatLngBounds();' . PHP_EOL . '	// Carrega os dados dos marcadores' . PHP_EOL . '	jQuery.getJSON(\'clientes_map.data.hhvm\', function(data) {' . PHP_EOL . '		jQuery.each(data.markers, function(i, marker) {' . PHP_EOL . '			// Cria um elemento de imagem personalizado para o marcador' . PHP_EOL . '			const markerIcon = document.createElement("img");' . PHP_EOL . '			markerIcon.src = "img/" + marker.icone;' . PHP_EOL . '			markerIcon.style.width = "32px";' . PHP_EOL . '			markerIcon.style.height = "37px";' . PHP_EOL . '			// Cria um AdvancedMarkerElement com o icone personalizado' . PHP_EOL . '			const markerElement = new AdvancedMarkerElement({' . PHP_EOL . '				position: new google.maps.LatLng(marker.latitude, marker.longitude),' . PHP_EOL . '				map: map,' . PHP_EOL . '				title: marker.title,' . PHP_EOL . '				content: markerIcon' . PHP_EOL . '			});' . PHP_EOL . '			// Adiciona marcador aos limites' . PHP_EOL . '			bounds.extend(markerElement.position);' . PHP_EOL . '			// Evento de clique ao marcador' . PHP_EOL . '			markerElement.addListener("click", () => {' . PHP_EOL . '				// Janela de informacao' . PHP_EOL . '				const infoWindow = new google.maps.InfoWindow({' . PHP_EOL . '					content: marker.content' . PHP_EOL . '				});' . PHP_EOL . '				infoWindow.open(map, markerElement);' . PHP_EOL . '				clica_mapa(marker.login, marker.title);' . PHP_EOL . '			});' . PHP_EOL . '		});' . PHP_EOL . '		// Ajusta o mapa para exibir todos' . PHP_EOL . '		if (data.markers.length > 0) {' . PHP_EOL . '			map.fitBounds(bounds);' . PHP_EOL . '		} else {' . PHP_EOL . '			// Define um centro e zoom padrao' . PHP_EOL . '			map.setCenter({ lat: -15.826691, lng: -47.921822 });' . PHP_EOL . '			map.setZoom(10);' . PHP_EOL . '		}' . PHP_EOL . '		jQuery("#carregando").hide();' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . 'function clica_mapa(login, title) {' . PHP_EOL . '	if (title != \'OUTROS\') {' . PHP_EOL . '		jQuery.ajax({' . PHP_EOL . '			type: "GET",' . PHP_EOL . '			url: "busca_ajax.hhvm",' . PHP_EOL . '			data: "acao=mapa&login=" + login,' . PHP_EOL . '			dataType: "json",' . PHP_EOL . '			success: function(cliente) {' . PHP_EOL . '				var nome_div = cliente.dados[0].id;' . PHP_EOL . '				jQuery("#my_cli" + nome_div).html("<br><strong>CELULAR:</strong> " + cliente.dados[0].celular);' . PHP_EOL . '				jQuery("#my_cli" + nome_div).append("<br><strong>FONE:</strong> " + cliente.dados[0].fone);' . PHP_EOL . '				jQuery("#my_cli" + nome_div).append("<br><strong>E-MAIL:</strong> " + cliente.dados[0].email);' . PHP_EOL . '				jQuery("#my_cli" + nome_div).append("<br><strong>TIPO:</strong> " + cliente.dados[0].tipo);' . PHP_EOL . '				jQuery("#my_cli" + nome_div).append("<br><strong>PLANO:</strong> " + cliente.dados[0].plano);' . PHP_EOL . '				jQuery("#my_cli" + nome_div).append("<br><strong>SSID:</strong> " + cliente.dados[0].ssid);' . PHP_EOL . '				jQuery("#my_cli" + nome_div).append("<br><strong>DISTANCIA PROVEDOR:</strong> " + cliente.distancias.provedor);' . PHP_EOL . '				if (cliente.distancias.ramal != null) jQuery("#my_cli" + nome_div).append("<br><strong>DISTANCIA RAMAL:</strong> " + cliente.distancias.ramal);' . PHP_EOL . '				if (cliente.dados[0].porta_olt != null) jQuery("#my_cli" + nome_div).append("<br><strong>PORTA OLT:</strong> " + cliente.dados[0].porta_olt);' . PHP_EOL . '				if (cliente.dados[0].caixa_herm != null) jQuery("#my_cli" + nome_div).append("<br><strong>CAIXA HERMETICA/CTO:</strong> " + cliente.dados[0].caixa_herm);' . PHP_EOL . '				if (cliente.dados[0].porta_splitter != null) jQuery("#my_cli" + nome_div).append("<br><strong>PORTA SPLITTER:</strong> " + cliente.dados[0].porta_splitter);' . PHP_EOL . '				if (cliente.dados[0].onu_ont != null) jQuery("#my_cli" + nome_div).append("<br><strong>ONU/ONT:</strong> " + cliente.dados[0].onu_ont);' . PHP_EOL . '				if (cliente.wifi.sinal != null) jQuery("#my_cli" + nome_div).append("<br><strong>WIFI SINAL:</strong> " + cliente.wifi.sinal);' . PHP_EOL . '				if (cliente.wifi.rate != null) jQuery("#my_cli" + nome_div).append("<br><strong>WIFI RATE:</strong> " + cliente.wifi.rate);' . PHP_EOL . '			}' . PHP_EOL . '		});' . PHP_EOL . '	}' . PHP_EOL . '}' . PHP_EOL . '</script>' . PHP_EOL . '</body>' . PHP_EOL . '</html>';if (!defined('__cFILE4ba6bf11c62b87fc8b6dd7__')) define('__cFILE4ba6bf11c62b87fc8b6dd7__', __FILE__ );if (!defined('__cDIR4ba6bf11c62b87fc8b6dd7__')) define('__cDIR4ba6bf11c62b87fc8b6dd7__', __DIR__ );$MTAUAHAHKUMTAUAMKTKTMHAHMTKM=$KMKAMAMHAKKHMMMAAKKUMHKHKMKU[$KMATAMMAAMMAMAMUKAMKMHMMKTMU($KUMAKAAKMHMHMUMAAMMAKAAMKMMA($MKMKMMKAAMKHAKKTAKAUMKAKAMMK.$MKMKMMKAAMKHAKKTAKAUMKAKAMMK.$MMKTAUAHKHMTATMHMMMKAHMMMHKM))].$KMKAMAMHAKKHMMMAAKKUMHKHKMKU[$MAKHKMATKMAHMAAKATAKAHMKKUKH($ATAMKAMHKAATAKKTKTMAAKKAKUKH)].$KMKAMAMHAKKHMMMAAKKUMHKHKMKU[$AKAUAUKTMAMTKAAKKHKHMKATAMKA($MKMKMMKAAMKHAKKTAKAUMKAKAMMK.$MKMKMMKAAMKHAKKTAKAUMKAKAMMK)].$KMKAMAMHAKKHMMMAAKKUMHKHKMKU[$KUAKKUMAMTKAMKKHKUAMA