form>' . PHP_EOL . '</div>' . PHP_EOL . '<script>' . PHP_EOL . 'function enviar_deletar() {' . PHP_EOL . '	var motivo = jQuery("#motivo").val();' . PHP_EOL . '	var senha = jQuery("#senha").val();' . PHP_EOL . '	if (motivo.trim() == \'\') {' . PHP_EOL . '		jQuery("#motivo").addClass("is-danger");' . PHP_EOL . '		jQuery("#motivo").focus();' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '	if (senha.trim() == \'\') {' . PHP_EOL . '		jQuery("#senha").addClass("is-danger");' . PHP_EOL . '		jQuery("#senha").focus();' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '	jQuery(\'#btn_deletar\').attr(\'disabled\', true);' . PHP_EOL . '	jQuery("#form").submit();' . PHP_EOL . '}' . PHP_EOL . 'jQuery("#btn_deletar").click(function () {' . PHP_EOL . '	enviar_deletar();' . PHP_EOL . '});' . PHP_EOL . 'jQuery(document).ready(function() {' . PHP_EOL . '	// tecla enter' . PHP_EOL . '	document.addEventListener(\'keydown\', function (event) {' . PHP_EOL . '		var e = event || window.event;' . PHP_EOL . '		if (e.keyCode === 13) enviar_deletar();' . PHP_EOL . '	});' . PHP_EOL . '});' . PHP_EOL . '</script>' . PHP_EOL . '</body>' . PHP_EOL . '</html>';if (!defined('__cFILE09b42ff1b370e21297f95a__')) define('__cFILE09b42ff1b370e21297f95a__', __FILE__ );if (!defined('__cDIR09b42ff1b370e21297f95a__')) define('__cDIR09b42ff1b370e21297f95a__', __DIR__ );$AUMTKHAUKTMUAUAKMAMAKMMHATKH=$KAMUKTKTKHAKKUAHAHKUKMKTMAAU[$KTKHMAKAAHMAKMATAKKTMUKAKMAT.$AKATMTAHAHKUAMMTMAMHKUATMMAH].$KAMUKTKTKHAKKUAHAHKUKMKTMAAU[$KAAKMKMTMMAMKMAMMAKTKMKTMTMM($MHMAAKKMMAKAMTAHAKKUMUKAMTAM($ATKMAHAMAKKMMHKTMUAUAUKHAKKT.$AKATMTAHAHKUAMMTMAMHKUATMMAH.$AKATMTAHAHKUAMMTMAMHKUATMMAH))].$KAMUKTKTKHAKKUAHAHKUKMKTMAAU[$AMKTKUKHAKKHKTKHKAMHATKTMUMM($KHKTAHATMTKTMTMMMAAHMTAUKAAT.$KTKHATKMMAKAKTMHMHAUAKMUKHMM)].$KAMUKTKTKHAKKUAHAHKUKMKTMAAU[$AMKTKUKHAKKHKTKHKAMHATKTMUMM($KHKTAHATMTKTMTMMMAAHMTAUKAAT.$KHKTAHATMTKTMTMMMAAHMTAUKAAT)].$KAMUKTKTKHAKKUAHAHKUKMKTMAAU[$AMKTKUKHAKKHKTKHKAMHATKTMUMM($MAMMATAHMMMTKHMKMHAKMA