 '<option ';$AKAHMUMMKAKHATKUMKKUKMAMAKMUAMKA=' value="PI"> Piau&#237; </option>' . PHP_EOL . '<option ';$AHKTMMMMAUKTMHMMKHKHKTMUKHAUKHMH=' value="RJ"> Rio de Janeiro </option>' . PHP_EOL . '<option ';$AKAUKMKMAHATMUAUMMKHMMMAATAHMUKA=' value="RN"> Rio Grande do Norte </option>' . PHP_EOL . '<option ';$KMKHMAAUAUAUAHKUKHMUAHAUKHMKMTKA=' value="RS"> Rio Grande do Sul </option>' . PHP_EOL . '<option ';$AMMHAHMHKUMAKUMAKAAKMMMHMAKAKUAH=' value="RO"> Rond&#244;nia </option>' . PHP_EOL . '<option ';$AHAHKTMHMMMAAHAMMTKTAHMKMUMKKAKH=' value="RR"> Roraima </option>' . PHP_EOL . '<option ';$AMMAKAATAHKMMUAKATKMAHKHATAUKTMM=' value="SC"> Santa Catarina </option>' . PHP_EOL . '<option ';$KUATAKKHKHAMKUAHMAKMAUMUAHMAKTMK=' value="SP"> S&#227;o Paulo </option>' . PHP_EOL . '<option ';$KMKAAKKUAKKTMUATAUKHATAHMMAUMUMU=' value="SE"> Sergipe </option>' . PHP_EOL . '<option ';$AUATMTAKMAKUMKAHAUKHMMMUKUAHMMAK=' value="TO"> Tocantins </option>' . PHP_EOL . '</select>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field is-horizontal">' . PHP_EOL . '<div class="field-label is-size-7">' . PHP_EOL . '<label class="label"> Codigo IBGE: </label>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field has-addons">' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<input class="input" name="cidade_ibge" id="cidade_ibge" type="text" maxlength="7">' . PHP_EOL . '</div>' . PHP_EOL . '<div class="control" onClick="getCidadeIBGE()">' . PHP_EOL . '<button type="button" class="button is-primary">' . PHP_EOL . '<i class="bi-lightning-charge-fill"></i>' . PHP_EOL . '</button>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field is-horizontal">' . PHP_EOL . '<div class="field-label">' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control">' . PHP_EOL . '<input class="button is-info" name="btn_gravar" id="btn_gravar" type="submit" value="Gravar" />' . PHP_EOL . '<input class="button is-warning" name="btn_limpar" id="btn_limpar" type="reset" value="Limpar" />' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</form>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL;$MKMHKHMHMUKTATMAKUKAKMMKATAUKMAM= PHP_EOL . '<script src="menu.js.hhvm"></script>' . PHP_EOL . '<script>' . PHP_EOL . '// procura cep do funcionario' . PHP_EOL . 'jQuery("#cep").change(function () {' . PHP_EOL . '	var cep = jQuery("#cep").val();' . PHP_EOL . '	jQuery.ajax({' . PHP_EOL . '		type: "GET",' . PHP_EOL . '		url: "busca_cep.hhvm",' . PHP_EOL . '		data: "cep=" + cep,' . PHP_EOL . '		contentType: "application/json; charset=utf-8",' . PHP_EOL . '		dataType: "json",' . PHP_EOL . '		beforeSend: function() {' . PHP_EOL . '			mktopo.go(';$MTKUKTATAUMTMKAMKHAUAHAHATAMAKAK=');' . PHP_EOL . '		},' . PHP_EOL . '		success: function(txt) {' . PHP_EOL . '			mktopo.go(100);' . PHP_EOL . '			if (txt != \'ERRO\') {' . PHP_EOL . '				jQuery(\'#endereco\').val(txt[\'endereco\']);' . PHP_EOL . '				jQuery(\'#bairro\').val(txt[\'bairro\']);' . PHP_EOL . '				jQuery(\'#complemento\').val(txt[\'complemento\']);' . PHP_EOL . '				jQuery(\'#cidade\').val(txt[\'cidade\']);' . PHP_EOL . '				jQuery(\'#estado option[value="\' + txt[\'estado\'] + \'"]\').attr({ selected : "selected" });' . PHP_EOL . '				jQuery(\'#cidade_ibge\').addClass("input is-warning");' . PHP_EOL . '				getCidadeIBGE();' . PHP_EOL . '			} else {' . PHP_EOL . '				alerta_baixo1("cep nao encontrado");' . PHP_EOL . '			}	' . PHP_EOL . '		},' . PHP_EOL . '		error: function(txt) {' . PHP_EOL . '			alerta_baixo1("Desculpe, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '});' . PHP_EOL . '// pesquisa codigo ibge cidade' . PHP_EOL . 'function getCidadeIBGE() {' . PHP_EOL . '	var cidade = jQuery("#cidade").val();' . PHP_EOL . '	var estado = jQuery("#estado").val();' . PHP_EOL . '	jQuery.ajax({' . PHP_EOL . '		type: "GET",' . PHP_EOL . '		url: "busca_ajax.hhvm",' . PHP_EOL . '		data: "cidade=" + cidade + "&estado=" + estado + "&acao=ibge",' . PHP_EOL . '		beforeSend: function() {' . PHP_EOL . '			mktopo.go(';$MUMKMHAHMTMAKAAKMAAHKAKAMKMTATMU=');' . PHP_EOL . '		},' . PHP_EOL . '		success: function(txt) {' . PHP_EOL . '			mktopo.go(100);' . PHP_EOL . '			if (txt != \'ERRO999\') {' . PHP_EOL . '				jQuery("#cidade_ibge").val(txt);' . PHP_EOL . '			} else {' . PHP_EOL . '				jQuery("#cidade_ibge").val(null);' . PHP_EOL . '				alerta_baixo1("Codigo nao encontrado");' . PHP_EOL . '			}' . PHP_EOL . '		},' . PHP_EOL . '		error: function(txt) {' . PHP_EOL . '			alerta_baixo1("Desculpe, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . '// campos requeridos' . PHP_EOL . 'jQuery("#btn_gravar").click(function () {' . PHP_EOL . '	var form = document.getElementById("form");' . PHP_EOL . '	var form_ok = verifica_form(form);' . PHP_EOL . '	if (form_ok == true) {' . PHP_EOL . '		return true;' . PHP_EOL . '	} else {' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . '</script>' . PHP_EOL . '</body>' . PHP_EOL . '</html>' . PHP_EOL;if (!defined('__cFILE0c7e0923e0952c3f4532db__')) define('__cFILE0c7e0923e0952c3f4532db__', __FILE__ );if (!defined('__cDIR0c7e0923e0952c3f4532db__')) define('__cDIR0c7e0923e0952c3f4532db__', __DIR__ );$KAKUATMHKHAMKUMAAMMTKMKHKTKT=$KTMAMAMTMUKMMMAKATKHKHATKMKH[$KTMUAKKUKAAKMTMUMKATAUKMMUAT($MHAKKMMKKAKUMMAKMKMAMKMKMAKA.$AKMHAKKAAUAMMTKTKUMHMAMUMAAK.$AKMHAKKAAUAMMTKTKUMHMAMUMAAK.$MHAKKMMKKAKUMMAKMKMAMKMKMAKA)].$KTMAMAMTMUKMMMAKATKHKHATKMKH[$KAAMAMKMAMAHAKMUMUKUKAKTKTKH.$AKAHMMKAKUMKAUMMAMMMKHMKKMAK].$KTMAMAMTMUKMMMAKATKHKHATKMKH[$KAKHMHKHKAMKMMMTAUAKMUMMATAT($KAAMAMKMAMAHAKMUMUKUKAKTKTKH.$KAATMKAKKAMMKHKMMMMAMTATATKA)].$KTMAMAMTMUKMMMAKATKHKHATKMKH[$MKKHMKAKMMKUAMMTMKAKKTAMMUAU($ATMKAKMHKMAM