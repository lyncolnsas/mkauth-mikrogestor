nciat">' . PHP_EOL . '<div class="field-label is-size-7">' . PHP_EOL . '<label class="label"> Token da inst&#226;ncia:: </label>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<input class="input" name="instancia_token" id="instancia_token" type="text" placeholder="Token da inst&#226;ncia:" value="';$AKMMMTMKAHAKKAMMKUMUAKAKKAKAATAM='" maxlength="192">' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field is-horizontal" id="div_token">' . PHP_EOL . '<div class="field-label is-size-7">' . PHP_EOL . '<label class="label"> Token: </label>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<input class="input" name="token" id="token" type="text" placeholder="Auth Token" value="';$KTKTMTMTKUAHMTAMMMKAKAMMMTKHKMMM='" maxlength="192">' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field is-horizontal" id="div_servidor">' . PHP_EOL . '<div class="field-label is-size-7">' . PHP_EOL . '<label class="label"> Servidor: </label>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<input class="input" name="wapp_host" id="wapp_host" type="text" placeholder="Endereco do servidor" value="';$MTMHMMAHKMKUKMMKAKMHMAMHMTMUMAAU='" maxlength="192">' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field is-horizontal" id="div_conta">' . PHP_EOL . '<div class="field-label is-size-7">' . PHP_EOL . '<label class="label"> Conta: </label>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<input class="input" name="wapp_login" id="wapp_login" type="text" placeholder="Conta do usuario" value="';$AUAHMAMHMHKMAKMTKAMHKUAHMHKTAKAH='" maxlength="128">' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field is-horizontal" id="div_senha">' . PHP_EOL . '<div class="field-label is-size-7">' . PHP_EOL . '<label class="label"> Senha: </label>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<input class="input" name="wapp_pass" id="wapp_pass" type="text" placeholder="Senha do usuario" value="';$AHKTATAUKAAUKUKUKTAUAKKHMKMUKHMT='" maxlength="128">' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field is-horizontal">' . PHP_EOL . '<div class="field-label">' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control">' . PHP_EOL . '<input class="button is-info" name="btn_gravar" id="btn_gravar" type="submit" value="Gravar" />' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</form>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="columns is-multiline">' . PHP_EOL . '<div class="column is-12 is-hidden-touch">' . PHP_EOL . '<div id="exZapPOST">' . PHP_EOL . '<span class="help">TR&#202;S ENDPOINTS DEVEM ESTAR DISPONIVEIS NA APLICA&#199;&#195;O PARA RECEBER OS DADOS DO MK-AUTH.</span>' . PHP_EOL . '<div class="columns is-multiline">' . PHP_EOL . '<div class="column is-12 is-hidden-mobile content is-small">' . PHP_EOL . '<div class="has-text-left" width="100%" border="0" align="center" cellpadding="0" cellspacing="0" style="padding: 15px; background-color: hsl(0, 0%, 96%);">' . PHP_EOL . '<span class="Host">';$AUMMMKMMKMMHAKKHMHMUAUKHMUAKMAKA='</span><strong>/send-message </strong> <br />' . PHP_EOL . '<span class="Host">';$MUKTKHMKAMAUKMMHAUAMAKKAMTMUMTMT='</span><strong>/send-image </strong> <br />' . PHP_EOL . '<span class="Host">';$AHMAMTMTKMMUAKKMKTMAAMMAKMAKAHMK='</span><strong>/send-document </strong> <br />' . PHP_EOL . '<span>Para visualizar exemplos do corpo da requisição de cada endpoint, consulte a documentação na Wiki. Você pode acessá-la clicando no botão de <i class="bi-question-circle"></i> ajuda localizado no canto inferior da tela.</span>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL;$KHMKKAKTMHATMTMHKHKAAKMUATKTMAKU= PHP_EOL . '<script src="menu.js.hhvm"></script>' . PHP_EOL . '<script>' . PHP_EOL . 'jQuery("#barra_msgs").click(function () {' . PHP_EOL . '	mka_link(\'conf_zap_msg.hhvm\');' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#barra_servidor").click(function () {' . PHP_EOL . '	mka_link(\'conf_zap_serv.hhvm\');' . PHP_EOL . '});' . PHP_EOL . 'function ajustarProtocolo(url) {' . PHP_EOL . '	const prefixoHttp = /^http[s]?:\\/\\//;' . PHP_EOL . '	return (url.length >= 8 && !prefixoHttp.test(url)) ? \'http://\' + url : url;' . PHP_EOL . '}' . PHP_EOL . '// mensagens de whatsapp' . PHP_EOL . 'function escolhe_zap(valor) {' . PHP_EOL . '	jQuery("#div_nodepost").hide();' . PHP_EOL . '	jQuery("#div_intancia").hide();' . PHP_EOL . '	jQuery("#div_token").hide();' . PHP_EOL . '	jQuery("#div_intanciat").hide();' . PHP_EOL . '	jQuery("#div_servidor").hide();' . PHP_EOL . '	jQuery("#div_conta").hide();' . PHP_EOL . '	jQuery("#div_senha").hide();' . PHP_EOL . '	jQuery("#exZapPOST").hide();' . PHP_EOL . '	if (valor == \'ultramsg\') get_ultramsg();' . PHP_EOL . '	if (valor == \'z_api\') get_z_api();' . PHP_EOL . '	if (valor == \'textmebot\') get_textmebot();' . PHP_EOL . '	if (valor == \'wapp_post\') get_wapphost();' . PHP_EOL . '	if (valor == \'evolution_api\') get_evolution_api();' . PHP_EOL . '	if (valor == \'evolution2_api\') get_evolution_api();' . PHP_EOL . '}' . PHP_EOL . 'function get_ultramsg() {' . PHP_EOL . '	jQuery("#div_intancia").show();' . PHP_EOL . '	jQuery("#div_token").show();' . PHP_EOL . '	jQuery("#div_intancia").find(\'label\').text(\' ID da instancia: \');' . PHP_EOL . '	jQuery("#div_token").find(\'label\').text(\' Token: \');' . PHP_EOL . '}' . PHP_EOL . 'function get_z_api() {' . PHP_EOL . '	jQuery("#div_intancia").show();' . PHP_EOL . '	jQuery("#div_intanciat").show();' . PHP_EOL . '	jQuery("#div_token").show();' . PHP_EOL . '	jQuery("#div_intanciat").find(\'label\').text(\' Token da instancia: \');' . PHP_EOL . '	jQuery("#div_token").find(\'label\').text(\' Token de seguranca da conta: \');' . PHP_EOL . '}' . PHP_EOL . 'function get_textmebot() {' . PHP_EOL . '	jQuery("#div_token").show();' . PHP_EOL . '	jQuery("#div_token").find(\'label\').text(\' ApiKey: \');' . PHP_EOL . '}' . PHP_EOL . 'function get_wapphost() {' . PHP_EOL . '	jQuery("#div_servidor").show();' . PHP_EOL . '	jQuery("#div_nodepost").show();' . PHP_EOL . '	jQuery("#div_conta").css(\'display\', \'\').find(\'label\').text(\' Conta: \');' . PHP_EOL . '	jQuery("#div_senha").css(\'display\', \'\').find(\'label\').text(\' Senha: \');' . PHP_EOL . '	jQuery("#exZapPOST").show();' . PHP_EOL . '}' . PHP_EOL . 'function get_evolution_api() {' . PHP_EOL . '	jQuery("#div_servidor").show();' . PHP_EOL . '	jQuery("#div_nodepost").hide();' . PHP_EOL . '	jQuery("#div_conta").css(\'display\', \'\').find(\'label\').text(\' Nome da instancia: \');' . PHP_EOL . '	jQuery("#div_senha").css(\'display\', \'\').find(\'label\').text(\' Token da instancia: \');' . PHP_EOL . '}' . PHP_EOL . 'function atualizarHost() {' . PHP_EOL . '	var v_host = jQuery("#wapp_host").val();' . PHP_EOL . '	if(v_host != \'\') {' . PHP_EOL . '		var status = /^https:\\/\\//.test(v_host);' . PHP_EOL . '		if (!status) v_host = ajustarProtocolo(v_host);' . PHP_EOL . '		jQuery(".Host").text(v_host);' . PHP_EOL . '	} else {' . PHP_EOL . '		jQuery(".Host").text(\'http://{url ou ip}\');' . PHP_EOL . '	}' . PHP_