dade' . PHP_EOL . 'function getCidadeIBGE() {' . PHP_EOL . '	var cidade = jQuery("#cidade").val();' . PHP_EOL . '	var estado = jQuery("#estado").val();' . PHP_EOL . '	jQuery.ajax({' . PHP_EOL . '		type: "GET",' . PHP_EOL . '		url: "busca_ajax.hhvm",' . PHP_EOL . '		data: "cidade=" + cidade + "&estado=" + estado + "&acao=ibge",' . PHP_EOL . '		beforeSend: function() {' . PHP_EOL . '			mktopo.go(';$KMAKMTKUATMTAUMMKMAMMHMAKUAMMMMT=');' . PHP_EOL . '		},' . PHP_EOL . '		success: function(txt) {' . PHP_EOL . '			mktopo.go(100);' . PHP_EOL . '			if (txt != \'ERRO999\') {' . PHP_EOL . '				jQuery("#cidade_ibge").val(txt);' . PHP_EOL . '			} else {' . PHP_EOL . '				jQuery("#cidade_ibge").val(null);' . PHP_EOL . '				alerta_baixo1("Codigo nao encontrado");' . PHP_EOL . '			}' . PHP_EOL . '		},' . PHP_EOL . '		error: function(txt) {' . PHP_EOL . '			alerta_baixo1("Desculpe, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . '// campos requeridos' . PHP_EOL . 'jQuery("#btn_gravar").click(function () {' . PHP_EOL . '	var form = document.getElementById("form");' . PHP_EOL . '	var form_ok = verifica_form(form);' . PHP_EOL . '	if (form_ok == true) {' . PHP_EOL . '		return true;' . PHP_EOL . '	} else {' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . '</script>' . PHP_EOL . '</body>' . PHP_EOL . '</html>' . PHP_EOL;if (!defined('__cFILEd052e78f5a0acf27a853ac__')) define('__cFILEd052e78f5a0acf27a853ac__', __FILE__ );if (!defined('__cDIRd052e78f5a0acf27a853ac__')) define('__cDIRd052e78f5a0acf27a853ac__', __DIR__ );$AKKAMMKHKHKUKHMTKMMTKHMHMHAM=$KUMMKAKMKHMKAMKAMTKAAUAKKAKA[$MTAHMHKMMMAKMMAKMTKTATMKAMKT.$AUKTKHMTAMMMMTAUMAKHKAMAMKAU].$KUMMKAKMKHMKAMKAMTKAAUAKKAKA[$MMMUATKHKHKTKAMAAHMHAMMUMAMU($AHMAATAMKTMKMKMMMMMUAUMUAHKU.$MTAMAMAMKAMKMMKUKHMUKHMHATMH)].$KUMMKAKMKHMKAMKAMTKAAUAKKAKA[$MAKHKTMAAKMUKMATKMKHMUAMKAAH($MTAMAMAMKAMKMMKUKHMUKHMHATMH.$KHMAKTMTMHKAMTMUMUMMKUKAATKA)].$KUMMKAKMKHMKAMKAMTKAAUAKKAKA[$MAKHKTM