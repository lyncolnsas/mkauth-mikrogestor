ace="2">\');' . PHP_EOL . '		},' . PHP_EOL . '		success: function(txt) {' . PHP_EOL . '			if (txt != \'VAZIO\') {' . PHP_EOL . '				jQuery("#caract_mais" + idlanc).hide();' . PHP_EOL . '				jQuery("#caract_menos" + idlanc).show();' . PHP_EOL . '				jQuery("#mais_conta" + idlanc).show();' . PHP_EOL . '				jQuery(\'#mostramais_conta\' + idlanc).html(txt);' . PHP_EOL . '			} else {' . PHP_EOL . '				jQuery("#caract_mais" + idlanc).hide();' . PHP_EOL . '				jQuery("#caract_menos" + idlanc).show();' . PHP_EOL . '				jQuery("#mais_conta" + idlanc).show();' . PHP_EOL . '				jQuery(\'#mostramais_conta\' + idlanc).html(\'<font style="color: hsl(348, 100%, 61%)">nada atrelado</font>\');' . PHP_EOL . '			}' . PHP_EOL . '		},' . PHP_EOL . '		error: function(txt) {' . PHP_EOL . '			alerta_baixo1("Desculpe, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . 'function delmais_conta(idlanc, idconta){' . PHP_EOL . '	// deleta mais conta' . PHP_EOL . '	jQuery.ajax({' . PHP_EOL . '		  type: "GET",' . PHP_EOL . '		  url: "executar_titulo.hhvm",' . PHP_EOL . '		  data: "acao=del_mais_conta&idconta=" + idconta,' . PHP_EOL . '		  beforeSend: function() {' . PHP_EOL . '			jQuery(\'#mostramais_conta\' + idlanc).html(\'<img src="img/mkload.gif" hspace="2" vspace="2">\');' . PHP_EOL . '		  },' . PHP_EOL . '		  success: function(txt) {' . PHP_EOL . '			if (txt==\'ERRO666\') {' . PHP_EOL . '			alerta_baixo1("Conta deletada");' . PHP_EOL . '			muda_valortotal(idlanc);' . PHP_EOL . '			aamm_mais(idlanc);' . PHP_EOL . '			}' . PHP_EOL . '		},' . PHP_EOL . '			error: function(txt) {' . PHP_EOL . '			alerta_baixo1("Desculpe, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . '// selecionador' . PHP_EOL . 'jQuery("#checkAll").click(function () {' . PHP_EOL . '	jQuery(\'input:checkbox\').not(this).prop(\'checked\', this.checked);' . PHP_EOL;$AHMAAMMAAUMKAUMTKHMTAMMTAHAMATAM='	if (jQuery("#checkAll").prop("checked")