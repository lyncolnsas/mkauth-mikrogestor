P_EOL . '</div>' . PHP_EOL . '<div id="contador"></div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<!-- mensagem wapp -->' . PHP_EOL . '<div class="field" id="areatexto_wapp" style="display: none">' . PHP_EOL . '<label class="label"> Mensagem: </label>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control is-expanded">' . PHP_EOL . '<textarea class="textarea is-fullwidth" name="texto_wapp" id="texto_wapp" rows="10">' . PHP_EOL . '</textarea>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<!-- mensagem wapp -->' . PHP_EOL . '<div class="field">' . PHP_EOL . '<label class="label"> ';$MKKTAKMTMKMMMUKUAUKUKUAHMHAHKAKA=' Carnes: </label>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control">' . PHP_EOL . '<div class="select is-multiple is-fullwidth">' . PHP_EOL . '<select name="destino[]" id="destino" multiple size="3">' . PHP_EOL;$MHMHAUKHAHMMKAMUMTMMKTKUAKKAMMAT='</select>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL;$KUATMTKTKMAKMTAMMUKTMMKHMHMTKUAT='<div class="field" id="div_pdf">' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control">' . PHP_EOL . '<input class="switch is-small" name="envia_pdf" id="envia_pdf" type="checkbox" value="sim" />' . PHP_EOL . '<label for="envia_pdf"><strong> ENVIAR PDF </strong></label>' . PHP_EOL . '</div>' . PHP_EOL;$MAKTKTKAMMAUMMMAMTMMMUMKMTMKMMAH='<p class="help is-danger is-hidden-mobile"><strong>Enviar muitas mensagens com PDF torna o processamento mais lento</strong></p>' . PHP_EOL;$KTKTMAMTAKMAMHMKKTMKMHKUAUKMKMMM='</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL;$KTMAMUAKAUMKKMAHMTMAMKAKKHAHKTMH='<div class="notification is-danger" id="div_pdf">' . PHP_EOL . 'Por momento somente eh possivel enviar PDF em no maximo 250 mensagens...' . PHP_EOL . '</div>' . PHP_EOL;$KUMHMAMUMAMUAMMUAUMMMAMHKHKMAMAK= PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="field-label">' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field-body">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<div class="control">' . PHP_EOL . '<button class="button is-info" id="enviar_msg" type="button"> Enviar </button>' . PHP_EOL . '<button class="button is-warning" id="cancelar_msg" type="button" onClick="window.close()"> Cancelar </button>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL;$KMMUKTAUMUMTKUKHAUAUMTKAMAATKMMA='</form>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="columns is-multiline">' . PHP_EOL . '<div class="column is-12 is-hidden-mobile">' . PHP_EOL . '<div id="variaveis">' . PHP_EOL;$ATATKUMTMTMAKTAMMUKAKAKTATMTAKKU='</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<script>' . PHP_EOL . 'jQuery("#enviar_msg").click(function () {' . PHP_EOL . '	const texto_wapp = jQuery("#texto_wapp").val();' . PHP_EOL . '	const texto = jQuery("#texto").val();' . PHP_EOL . '	const assunto = jQuery("#assunto").val();' . PHP_EOL . '	const msg = jQuery(\'#msg\').trumbowyg(\'html\');' . PHP_EOL . '	const geral = texto_wapp + texto + assunto + msg;' . PHP_EOL . '	localStorage.setItem("send_carne_texto_wapp", texto_wapp);' . PHP_EOL . '	localStorage.setItem("send_carne_texto", texto);' . PHP_EOL . '	localStorage.setItem("send_carne_assunto", assunto);' . PHP_EOL . '	localStorage.setItem("send_carne_msg", msg);' . PHP_EOL . '	localStorage.setItem("send_carne_geral", geral);' . PHP_EOL . '	jQuery(\'#enviar_msg\').attr(\'disabled\', true);' . PHP_EOL . '	jQuery("#form").submit();' . PHP_EOL . '});' . PHP_EOL . 'jQuery(document).on(\'click\', \'[data-variavel]\', function () {' . PHP_EOL . '	var variavel = jQuery(this).attr("data-variavel");' . PHP_EOL . '	var texto_wapp = jQuery("#texto_wapp").val();' . PHP_EOL . '	var texto = jQuery("#texto").val();' . PHP_EOL . '	var msg = jQuery(\'#msg\').trumbowyg(\'html\');' . PHP_EOL . '	jQuery("#texto_wapp").val(texto_wapp + \' \' +  variavel);' . PHP_EOL . '	jQuery("#texto").val(texto + \' \' +  variavel);' . PHP_EOL . '	jQuery(\'#msg\').trumbowyg(\'html\', msg + \' \' + variavel);' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#tiposend").on(\'change\', function() {' . PHP_EOL . '	var valor = jQuery(this).val();' . PHP_EOL . '	tipo_send_change(valor);' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#texto_wapp, #texto, #msg").on(\'keyup\', function() {' . PHP_EOL . '    const idElemento = jQuery(this).attr(\'id\');' . PHP_EOL . '    let valor = jQuery(this).val();' . PHP_EOL . '    if (idElemento === \'msg\') valor = strip_tags(jQuery("#msg").trumbowyg(\'html\'));' . PHP_EOL . '    if (idElemento === \'texto\') jQuery("#contador").html(\'Total de \' + valor.length + \' caracteres\');' . PHP_EOL . '    if (valor.length > 0 && valor.length % 3 === 0) {' . PHP_EOL . '        const ultimaPalavra = valor.trim().split(\' \').pop();' . PHP_EOL . '        sugestao(ultimaPalavra);' . PHP_EOL . '    }' . PHP_EOL . '});' . PHP_EOL . 'function tipo_send_change(valor) {' . PHP_EOL . '	jQuery("#div_assunto").hide();' . PHP_EOL . '	jQuery("#div_msg").hide();' . PHP_EOL . '	jQuery("#div_texto").hide();' . PHP_EOL . '	jQuery("#div_pdf").hide();' . PHP_EOL . '	jQuery("#wapp_tipo").hide();' . PHP_EOL . '	jQuery("#areatexto_wapp").hide();' . PHP_EOL . '	jQuery(\'#tiposend option[value="email"]\').removeAttr("selected");' . PHP_EOL . '	jQuery(\'#tiposend option[value="sms"]\').removeAttr("selected");' . PHP_EOL . '	jQuery(\'#tiposend option[value="wapp"]\').removeAttr("selected");' . PHP_EOL . '	jQuery(\'#tiposend option[value="wapp_web"]\').removeAttr("selected");' . PHP_EOL . '	jQuery("#tiposend").val(valor);' . PHP_EOL . '	switch (valor) {' . PHP_EOL . '		case "email":' . PHP_EOL . '			jQuery("#div_assunto").show();' . PHP_EOL . '			jQuery("#div_msg").show();' . PHP_EOL . '			jQuery("#div_pdf").show();' . PHP_EOL . '			if (localStorage.getItem("send_carne_assunto") !== null) jQuery("#assunto").val(localStorage.getItem("send_carne_assunto"));' . PHP_EOL . '			if (localStorage.getItem("send_carne_msg") !== null) jQuery(\'#msg\').trumbowyg(\'html\', localStorage.getItem("send_carne_msg"));' . PHP_EOL . '		break;' . PHP_EOL . '		case "sms":' . PHP_EOL . '			jQuery("#div_texto").show();' . PHP_EOL . '			if (localStorage.getItem("send_carne_texto") !== null) jQuery("#texto").val(localStorage.getItem("send_carne_texto"));' . PHP_EOL . '		break;' . PHP_EOL . '		case "wapp":' . PHP_EOL . '			jQuery("#wapp_tipo").show();' . PHP_EOL . '			jQuery("#areatexto_wapp").show();' . PHP_EOL . '			jQuery("#div_pdf").show();' . PHP_EOL . '			if (localStorage.getItem("send_carne_texto_wapp") !== null) jQuery("#texto_wapp").val(localStorage.getItem("send_carne_texto_wapp"));' . PHP_EOL . '		break;' . PHP_EOL . '		case "wapp_web":' . PHP_EOL . '			jQuery("#div_texto").show();' . PHP_EOL . '			if (localStorage.getItem("send_carne_texto") !== null) jQuery("#texto").val(localStorage.getItem("send_carne_texto"));' . PHP_EOL . '		break;' . PHP_EOL . '	}' . PHP_EOL . '}' . PHP_EOL . 'function sugestao(texto) {' . PHP_EOL . '	let txt_geral = \'\';' . PHP_EOL . '	if (localStorage.getItem("send_carne_geral") !== null) txt_geral = localStorage.getItem("send_carne_geral");' . PHP_EOL . '	let variaveis = [' . PHP_EOL;$AKMAMMKTMKKTMMMMMMATKTAUMKMKKAMA='];' . PHP_EOL . '	variaveis = shuffle(variaveis);' . PHP_EOL . '	let valores = variaveis;' . PHP_EOL . '	const usadas = variaveis.filter(variavel => txt_geral.includes(variavel));' . PHP_EOL . '	if (usadas.length >= 4) valores = usadas;' . PHP_EOL . '	jQuery(\'#btn_variavel0\').attr(\'data-variavel\', valores[0]);' . PHP_EOL . '	jQuery(\'#txt_variavel0\').html(valores[0]);' . PHP_EOL . '	jQuery(\'#btn_variavel1\').attr(\'data-variavel\', valores[1]);' . PHP_EOL . '	jQuery(\'#txt_variavel1\').html(valores[1]);