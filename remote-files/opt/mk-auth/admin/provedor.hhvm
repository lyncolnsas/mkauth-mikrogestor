e, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . '// carreta icms pelo estado escolhido' . PHP_EOL . 'function getListaICMS() {' . PHP_EOL . '	var estado = jQuery("#estado").val();' . PHP_EOL . '	jQuery.getJSON("busca_ajax.hhvm?acao=sped&estado=" + estado, function(json) {' . PHP_EOL . '		jQuery(\'#codigo_receita\').empty();' . PHP_EOL . '		jQuery.each(json, function(i, obj){' . PHP_EOL . '		if (obj.codigo != undefined) {' . PHP_EOL . '			jQuery(\'#codigo_receita\').append(jQuery(\'<option>\').html(obj.codigo + \' - \' + obj.texto).attr(\'value\', obj.codigo));' . PHP_EOL . '		}' . PHP_EOL . '		});' . PHP_EOL . '		jQuery(\'#codigo_receita option[value="';$KUMKAHAHMUMAMUMMMTMHAHMTKHMHAUMT='"]\').attr({ selected : "selected" });' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . 'jQuery("#estado").change(function() {' . PHP_EOL . '	getListaICMS();' . PHP_EOL . '});' . PHP_EOL . '// tab cadastro' . PHP_EOL . 'jQuery("#barra_cadastro").click(function () {' . PHP_EOL . '	escolhe_opcao(\'cadastro\');' . PHP_EOL . '});' . PHP_EOL . '// tab fiscal' . PHP_EOL . 'jQuery("#barra_fiscal").click(function () {' . PHP_EOL . '	escolhe_opcao(\'fiscal\');' . PHP_EOL . '});' . PHP_EOL . '// tab midia' . PHP_EOL . 'jQuery("#barra_midia").click(function () {' . PHP_EOL . '	escolhe_opcao(\'midia\');' . PHP_EOL . '});' . PHP_EOL . '// campos requeridos' . PHP_EOL . 'jQuery("#btn_gravar").click(function () {' . PHP_EOL . '	var form = document.getElementById("form");' . PHP_EOL . '	var form_ok = verifica_form(form);' . PHP_EOL . '	if (form_ok == true) {' . PHP_EOL . '		return true;' . PHP_EOL . '	} else {' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . '// readyDOM completo' . PHP_EOL . 'jQuery(document).ready(function() {' . PHP_EOL . '	escolhe_opcao(\'cadastro\');' . PHP_EOL . '	getListaICMS();' . PHP_EOL . '	verLogo();' . PHP_EOL;$AUMAAMMTKHMAMUAUATMAKMKTKUAUKMMU='	alerta_baixo2(\'E-Mail invalido...\');' . PHP_EO