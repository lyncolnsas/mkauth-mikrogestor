 PHP_EOL . '	localStorage.setItem("send_chamado_geral", geral);' . PHP_EOL . '	jQuery(\'#enviar_msg\').attr(\'disabled\', true);' . PHP_EOL . '	jQuery("#form").submit();' . PHP_EOL . '});' . PHP_EOL . 'jQuery(document).on(\'click\', \'[data-variavel]\', function () {' . PHP_EOL . '	var variavel = jQuery(this).attr("data-variavel");' . PHP_EOL . '	var texto_wapp = jQuery("#texto_wapp").val();' . PHP_EOL . '	var texto = jQuery("#texto").val();' . PHP_EOL . '	var msg = jQuery(\'#msg\').trumbowyg(\'html\');' . PHP_EOL . '	var legenda_img = jQuery(\'#legenda_img\').val();' . PHP_EOL . '	var legenda_file = jQuery(\'#legenda_file\').val();' . PHP_EOL . '	jQuery("#texto_wapp").val(texto_wapp + \' \' +  variavel);' . PHP_EOL . '	jQuery("#texto").val(texto + \' \' +  variavel);' . PHP_EOL . '	jQuery(\'#msg\').trumbowyg(\'html\', msg + \' \' + variavel);' . PHP_EOL . '	jQuery("#legenda_img").val(legenda_img + \' \' +  variavel);' . PHP_EOL . '	jQuery("#legenda_file").val(legenda_file + \' \' +  variavel);' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#tiposend").on(\'change\', function() {' . PHP_EOL . '	var valor = jQuery(this).val();' . PHP_EOL . '	tipo_send_change(valor);' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#texto_wapp, #texto, #msg, #legenda_img, #legenda_file").on(\'keyup\', function() {' . PHP_EOL . '    const idElemento = jQuery(this).attr(\'id\');' . PHP_EOL . '    let valor = jQuery(this).val();' . PHP_EOL . '    if (idElemento === \'msg\') valor = strip_tags(jQuery("#msg").trumbowyg(\'html\'));' . PHP_EOL . '    if (idElemento === \'texto\') jQuery("#contador").html(\'Total de \' + valor.length + \' caracteres\');' . PHP_EOL . '    if (valor.length > 0 && valor.length % 3 === 0) {' . PHP_EOL . '        const ultimaPalavra = valor.trim().split(\' \').pop();' . PHP_EOL . '        sugestao(ultimaPalavra);' . PHP_EOL . '    }' . PHP_EOL . '});' . PHP_EOL . 'jQuery(".is-checkradio").on(\'click\', function() {' . PHP_EOL . '	var valor = jQuery(this).val();' . PHP_EOL . '	if (valor == 1) {' . PHP_EOL . '		jQuery("#areatexto_wapp").show();' . PHP_EOL . '		jQuery("#divfoto").hide();' . PHP_EOL . '		jQuery("#divpdf").hide();' . PHP_EOL . '	} else if (valor == 2) {' . PHP_EOL . '		jQuery("#divfoto").show();' . PHP_EOL . '		jQuery("#areatexto_wapp").hide();' . PHP_EOL . '		jQuery("#divpdf").hide();' . PHP_EOL . '	} else if (valor == 3) {' . PHP_EOL . '		jQuery("#divpdf").show();' . PHP_EOL . '		jQuery("#areatexto_wapp").hide();' . PHP_EOL . '		jQuery("#divfoto").hide();' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#img_00").change(function() {' . PHP_EOL . '    const arquivo = jQuery("#img_00")[0].files[0];' . PHP_EOL . '    const maxSize = 2097152; // 2MB' . PHP_EOL . '    const imagemVisivel = jQuery("#imagem_visivel");' . PHP_EOL . '    const avisoImg = jQuery("#aviso_img");' . PHP_EOL . '    const base64Img = jQuery("#base64_img");' . PHP_EOL . '    if (arquivo && arquivo.size < maxSize) {' . PHP_EOL . '        imagemVisivel.css("border", "solid #F0F0F0");' . PHP_EOL . '        avisoImg.hide();' . PHP_EOL . '        const reader = new FileReader();' . PHP_EOL . '        reader.onload = function(e) {' . PHP_EOL . '            const fotoBase64 = e.target.result;' . PHP_EOL . '            base64Img.val(fotoBase64);' . PHP_EOL . '            imagemVisivel.attr(\'src\', fotoBase64);' . PHP_EOL . '        };' . PHP_EOL . '        reader.readAsDataURL(arquivo);' . PHP_EOL . '    } else {' . PHP_EOL . '        imagemVisivel.css("border", "solid #FF0000");' . PHP_EOL . '        avisoImg.show();' . PHP_EOL . '    }' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#file_00").change(function() {' . PHP_EOL . '    const arquivo = jQuery("#file_00")[0].files[0];' . PHP_EOL . '    if (arquivo) {' . PHP_EOL . '        const reader = new FileReader();' . PHP_EOL . '        ' . PHP_EOL . '        reader.onload = function(e) {' . PHP_EOL . '            const arquivoBase64 = e.target.result;' . PHP_EOL . '            const arquivoNome = arquivo.name;' . 