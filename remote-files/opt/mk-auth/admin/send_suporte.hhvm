' . PHP_EOL . '			jQuery("#divfoto").hide();' . PHP_EOL . '			jQuery("#divpdf").hide();' . PHP_EOL . '			if (localStorage.getItem("send_chamado_texto_wapp") !== null) jQuery("#texto_wapp").val(localStorage.getItem("send_chamado_texto_wapp"));' . PHP_EOL . '		break;' . PHP_EOL . '		case "wapp_web":' . PHP_EOL . '			jQuery("#div_texto").show();' . PHP_EOL . '			if (localStorage.getItem("send_chamado_texto") !== null) jQuery("#texto").val(localStorage.getItem("send_chamado_texto"));' . PHP_EOL . '		break;' . PHP_EOL . '	}' . PHP_EOL . '}' . PHP_EOL . 'function sugestao(texto) {' . PHP_EOL . '	let txt_geral = \'\';' . PHP_EOL . '	if (localStorage.getItem("send_chamado_geral") !== null) txt_geral = localStorage.getItem("send_chamado_geral");' . PHP_EOL . '	let variaveis = [' . PHP_EOL;$MHMTMKKAKHMAKHMTMKKTMAKTAMMUKHAT='];' . PHP_EOL . '	variaveis = shuffle(variaveis);' . PHP_EOL . '	let valores = variaveis;' . PHP_EOL . '	const usadas = variaveis.filter(variavel => txt_geral.includes(variavel));' . PHP_EOL . '	if (usadas.length >= 4) valores = usadas;' . PHP_EOL . '	jQuery(\'#btn_variavel0\').attr(\'data-variavel\', valores[0]);' . PHP_EOL . '	jQuery(\'#txt_variavel0\').html(valores[0]);' . PHP_EOL . '	jQuery(\'#btn_variavel1\').attr(\'data-variavel\', valores[1]);' . PHP_EOL . '	jQuery(\'#txt_variavel1\').html(valores[1]);' . PHP_EOL . '	jQuery(\'#btn_variavel2\').attr(\'data-variavel\', valores[2]);' . PHP_EOL . '	jQuery(\'#txt_variavel2\').html(valores[2]);' . PHP_EOL . '	jQuery(\'#btn_variavel3\').attr(\'data-variavel\', valores[3]);' . PHP_EOL . '	jQuery(\'#txt_variavel3\').html(valores[3]);' . PHP_EOL . '	if (texto != null) {' . PHP_EOL . '		markov_chain.addTexto(txt_geral);' . PHP_EOL . '		const atual_palavra = texto;' . PHP_EOL . '		const proxima_palavra = markov_chain.getProximaPalavra(atual_palavra);' . PHP_EOL . '		if (proxima_palavra != null) {' . PHP_EOL . '			if (in_array(proxima_palavra, variaveis)) {' . PHP_EOL . '				jQuery(\'#btn_variavel0\').attr(\'dat