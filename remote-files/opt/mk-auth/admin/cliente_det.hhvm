. PHP_EOL . '// atualiza valor total' . PHP_EOL . 'function muda_valortotal(idlanc) {' . PHP_EOL . '	jQuery.ajax({' . PHP_EOL . '	type: "GET",' . PHP_EOL . '	url: "busca_ajax.hhvm",' . PHP_EOL . '	data: "acao=valottotal&idlanc=" + idlanc,' . PHP_EOL . '	success: function(txt) {' . PHP_EOL . '			jQuery(\'#valor_tot\' + idlanc).html(txt);' . PHP_EOL . '		},' . PHP_EOL . '	error: function(txt) {' . PHP_EOL . '			alerta_baixo1("Desculpe, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . '// ver mais contas do titulo' . PHP_EOL . 'function aamm_mais(idlanc) {' . PHP_EOL . '	jQuery.ajax({' . PHP_EOL . '		type: "GET",' . PHP_EOL . '		url: "mais_titulo.hhvm",' . PHP_EOL . '		data: "idlanc=" + idlanc,' . PHP_EOL . '		beforeSend: function() {' . PHP_EOL . '			jQuery("#mais_conta" + idlanc).show();' . PHP_EOL . '			jQuery(\'#mostramais_conta\' + idlanc).html(\'<img src="img/mkload.gif" hspace="2" vspace="2">\');' . PHP_EOL . '		},' . PHP_EOL . '		success: function(txt) {' . PHP_EOL . '			if (txt != \'VAZIO\') {' . PHP_EOL . '				jQuery("#caract_mais" + idlanc).hide();' . PHP_EOL . '				jQuery("#caract_menos" + idlanc).show();' . PHP_EOL . '				jQuery("#mais_conta" + idlanc).show();' . PHP_EOL . '				jQuery(\'#mostramais_conta\' + idlanc).html(txt);' . PHP_EOL . '			} else {' . PHP_EOL . '				jQuery("#caract_mais" + idlanc).hide();' . PHP_EOL . '				jQuery("#caract_menos" + idlanc).show();' . PHP_EOL . '				jQuery("#mais_conta" + idlanc).show();' . PHP_EOL . '				jQuery(\'#mostramais_conta\' + idlanc).html(\'<font style="color: hsl(348, 100%, 61%)">nada atrelado</font>\');' . PHP_EOL . '			}' . PHP_EOL . '		},' . PHP_EOL . '		error: function(txt) {' . PHP_EOL . '			alerta_baixo1("Desculpe, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . '// ver mais contas do titulo' . PHP_EOL . 'function aamm_mais_carne(carne) {' . PHP_EOL . '	jQuery.ajax({' . PHP_EOL . '		type: "GET",' . PHP_EOL . '		u