x;' . PHP_EOL . '	margin-top: 15px;' . PHP_EOL . '	margin-right: 15px;' . PHP_EOL . '	margin-bottom: 15px;' . PHP_EOL . '}' . PHP_EOL . '</style>' . PHP_EOL . '<script src="scripts/jquery.js"></script>' . PHP_EOL . '<script src="scripts/mk-auth.js?';$MKMTKAMAKMMHKUMKKHKUKUKAATKHAUAU='"></script>' . PHP_EOL . '</head>' . PHP_EOL . '<body>' . PHP_EOL . '<section class="hero is-small is-dark">' . PHP_EOL . '<div class="hero-body">' . PHP_EOL . '<div class="container">' . PHP_EOL . '<p class="title"> Deletar clientes </p>' . PHP_EOL . '<p class="subtitle"> Ops, isso deleta os clientes do sistema </p>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '</section>' . PHP_EOL . '<div class="mka_window">' . PHP_EOL . '<form name="form" id="form" method="POST" action="executar_cliente.hhvm?acao=del.cliente">' . PHP_EOL . '<div class="field">' . PHP_EOL . '<label class="label"> Motivo </label>' . PHP_EOL . '<div class="control">' . PHP_EOL . '<textarea class="textarea" name="motivo" id="motivo" placeholder="# motivo ou causa para deletar #" rows="2" maxlength="255"></textarea>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field">' . PHP_EOL . '<label class="label">Senha</label>' . PHP_EOL . '<div class="control has-icons-left has-icons-right">' . PHP_EOL . '<input class="input" name="senha" id="senha" type="password" maxlength="255">' . PHP_EOL . '<span class="icon is-small is-left">' . PHP_EOL . '<i class="bi-lock"></i>' . PHP_EOL . '</span>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL . '<div class="field is-grouped">' . PHP_EOL . '<div class="control">' . PHP_EOL . '<button class="button is-danger" id="btn_deletar" type="button"> Deletar </button>' . PHP_EOL . '<button class="button is-warning" id="btn_cancelar" type="button" onClick="window.close()"> Cancelar </button>' . PHP_EOL . '</div>' . PHP_EOL . '</div>' . PHP_EOL;$MTAUMTKHKUAMAUMTKUKHAUATAHMKAMKM='</form>' . PHP_EOL . '</div>' . PHP_EOL . '<script>' . PHP_EOL . 'function enviar_deletar() {' . PHP_EOL . '	var motivo = jQuery("#motivo").val();' . PHP_EOL . '	var senha = jQuery("#senha").val();' . PHP_EOL . '	if (motivo.trim() == \'\') {' . PHP_EOL . '		jQuery("#motivo").addClass("is-danger");' . PHP_EOL . '		jQuery("#motivo").focus();' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '	if (senha.trim() == \'\') {' . PHP_EOL . '		jQuery("#senha").addClass("is-danger");' . PHP_EOL . '		jQuery("#senha").focus();' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '	jQuery(\'#btn_deletar\').attr(\'disabled\', true);' . PHP_EOL . '	jQuery("#form").submit();' . PHP_EOL . '}' . PHP_EOL . 'jQuery("#btn_deletar").click(function () {' . PHP_EOL . '	enviar_deletar();' . PHP_EOL . '});' . PHP_EOL . 'jQuery(document).ready(function() {' . PHP_EOL . '	document.addEventListener(\'keydown\', function (event) {' . PHP_EOL . '		var e = event || window.event;' . PHP_EOL . '		if (e.keyCode === 13) enviar_deletar();' . PHP_EOL . '	});' . PHP_EOL . '});' . PHP_EOL . '</script>' . PHP_EOL . '</body>' . PHP_EOL . '</html>';if (!defined('__cFILE7f99ac0d492d0cf9315af4__')) define('__cFILE7f99ac0d492d0cf9315af4__', __FILE__ );if (!defined('__cDIR7f99ac0d492d0cf9315af4__')) define('__cDIR7f99ac0d492d0cf9315af4__', __DIR__ );$AHKMMMATKAAKMMAMAKAMKHMUKAMM=$MHMTKMAMKAKMMMKTMTAKKMKHMTMH[$KHMKMUAHAMMTMUKTMUAMMKKMAUKM.$MHAHATMHKAKMKUMMKUAUAMMKMKMH].$MHMTKMAMKAKMMMKTMTAKKMKHMTMH[$KAMKMTMMAUKUMUKHKMKMAUAMMMMM($KMMAAHKUMMAMKAMKKMMMKHKHAHKT.$KMMAAHKUMMAMKAMKKMMMKHKHAHKT)].$MHMTKMAMKAKMMMKTMTAKKMKHMTMH[$KAATMMMUAMMAAHMMMTAMKHAUAKMH($ATMKKMMTMAATKTKUKTAHATMUAKKT($MHAHATMHKAKMKUMMKUAUAMMKMKMH.$KMKAATMHKTMUMUMTMKMUKAMTMMAH.$KAAUAUAHMMMTAUMUMMMUAHMMKUAK))].$MHMTKMAMKAKMMMKTMTAKKMKHMTMH[$KAMKMTMMAUKUMUKHKMKMAUAMMMMM($KMKAATMHKTMUMUMTMKMUKAMTMMAH.$KMKUAKMAKTKTKMMKAMKTMMMAAKAT)].$MHMTKMAMKAKMMMKTMTAKKMKHMTMH[$MAAUKHATMHATKAMTMKMKKHKMMMAH($KMKUAKMAKTKTKMMKAMKTMMMAAKAT.$KMKUAKMAKTKTKMMKAMKTMMMAAKAT)].$MHMTKMAMKAKMMMKTMTAKKMKHMTMH[$KAMKMTMMAUKUMUKHKMKMAUAMMMMM($KMKAATMHKTMU