 () {' . PHP_EOL . '	if (confirm(\'Realmente deseja deletar estes arquivos?\')) {' . PHP_EOL . '		jQuery("#form_combox").attr(\'action\', "executar_backup.hhvm?acao=del.backup");' . PHP_EOL . '		jQuery("#form_combox").attr(\'target\', "_parent");' . PHP_EOL . '		jQuery("#form_combox").submit();' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . '// configurar backup' . PHP_EOL . 'jQuery("#run_configurar").click(function () {' . PHP_EOL . '	mka_link(\'conf_backup.hhvm\');' . PHP_EOL . '});' . PHP_EOL . '// restaura um backup' . PHP_EOL . 'function restaurar_ajax(arquivo) {' . PHP_EOL . '	jQuery.ajax({' . PHP_EOL . '		type: "GET",' . PHP_EOL . '		url: "executar_backup.hhvm",' . PHP_EOL . '		data: "acao=res.backup&arquivo=" + arquivo,' . PHP_EOL . '		beforeSend: function() {' . PHP_EOL . '			mktopo.go(';$MUKTKTMKAHMUKAAKMTKUATMUKAMTMAAK=');' . PHP_EOL . '		},' . PHP_EOL . '		success: function(txt) {' . PHP_EOL . '			if (txt == \'OK\') {' . PHP_EOL . '				mktopo.go(100);' . PHP_EOL . '				alerta_baixo1("Backup restaurado com sucesso");' . PHP_EOL . '			}' . PHP_EOL . '		},' . PHP_EOL . '		error: function(txt) {' . PHP_EOL . '			alerta_baixo1("Desculpe, houve um problema interno");' . PHP_EOL . '		}' . PHP_EOL . '	});' . PHP_EOL . '}' . PHP_EOL . '// selecionador' . PHP_EOL . 'jQuery("#checkAll").click(function () {' . PHP_EOL . '	jQuery(\'input:checkbox\').not(this).prop(\'checked\', this.checked);' . PHP_EOL . '});' . PHP_EOL . '// abre link de restauracao' . PHP_EOL . 'jQuery(document).on(\'click\', \'#link_restaurar\', function () {' . PHP_EOL . '	var arq_backup = jQuery(this).attr("data-arquivo");' . PHP_EOL . '	if (confirm(\'Deseja restaurar o backup \' + arq_backup + \' no sistema?\')) {' . PHP_EOL . '		restaurar_ajax(arq_backup);' . PHP_EOL . '		return false;' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . '</script>' . PHP_EOL . '</body>' . PHP_EOL . '</html>';if (!defined('__cFILEa404987eb612f67a13ee6f__')) define('__cFILEa404987eb612