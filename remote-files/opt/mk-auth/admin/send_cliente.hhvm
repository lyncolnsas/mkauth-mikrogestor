OL . '	jQuery(\'#msg\').trumbowyg(\'html\', msg + \' \' + variavel);' . PHP_EOL . '	jQuery("#legenda_img").val(legenda_img + \' \' +  variavel);' . PHP_EOL . '	jQuery("#legenda_file").val(legenda_file + \' \' +  variavel);' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#tiposend").on(\'change\', function() {' . PHP_EOL . '	var valor = jQuery(this).val();' . PHP_EOL . '	tipo_send_change(valor);' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#texto_wapp, #texto, #msg, #legenda_img, #legenda_file").on(\'keyup\', function() {' . PHP_EOL . '    const idElemento = jQuery(this).attr(\'id\');' . PHP_EOL . '    let valor = jQuery(this).val();' . PHP_EOL . '    if (idElemento === \'msg\') valor = strip_tags(jQuery("#msg").trumbowyg(\'html\'));' . PHP_EOL . '    if (idElemento === \'texto\') jQuery("#contador").html(\'Total de \' + valor.length + \' caracteres\');' . PHP_EOL . '    if (valor.length > 0 && valor.length % 3 === 0) {' . PHP_EOL . '        const ultimaPalavra = valor.trim().split(\' \').pop();' . PHP_EOL . '        sugestao(ultimaPalavra);' . PHP_EOL . '    }' . PHP_EOL . '});' . PHP_EOL . 'jQuery(".is-checkradio").on(\'click\', function() {' . PHP_EOL . '	var valor = jQuery(this).val();' . PHP_EOL . '	if (valor == 1) {' . PHP_EOL . '		jQuery("#areatexto_wapp").show();' . PHP_EOL . '		jQuery("#divfoto").hide();' . PHP_EOL . '		jQuery("#divpdf").hide();' . PHP_EOL . '	} else if (valor == 2) {' . PHP_EOL . '		jQuery("#divfoto").show();' . PHP_EOL . '		jQuery("#areatexto_wapp").hide();' . PHP_EOL . '		jQuery("#divpdf").hide();' . PHP_EOL . '	} else if (valor == 3) {' . PHP_EOL . '		jQuery("#divpdf").show();' . PHP_EOL . '		jQuery("#areatexto_wapp").hide();' . PHP_EOL . '		jQuery("#divfoto").hide();' . PHP_EOL . '	}' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#img_00").change(function() {' . PHP_EOL . '    const arquivo = jQuery("#img_00")[0].files[0];' . PHP_EOL . '    const maxSize = 2097152; // 2MB' . PHP_EOL . '    const imagemVisivel = jQuery("#imagem_visivel");' . PHP_EOL . '    const avisoImg = jQuery("#aviso_img");' . PHP_EOL . '    const base64Img = jQuery("#base64_img");' . PHP_EOL . '    if (arquivo && arquivo.size < maxSize) {' . PHP_EOL . '        imagemVisivel.css("border", "solid #F0F0F0");' . PHP_EOL . '        avisoImg.hide();' . PHP_EOL . '        const reader = new FileReader();' . PHP_EOL . '        reader.onload = function(e) {' . PHP_EOL . '            const fotoBase64 = e.target.result;' . PHP_EOL . '            base64Img.val(fotoBase64);' . PHP_EOL . '            imagemVisivel.attr(\'src\', fotoBase64);' . PHP_EOL . '        };' . PHP_EOL . '        reader.readAsDataURL(arquivo);' . PHP_EOL . '    } else {' . PHP_EOL . '        imagemVisivel.css("border", "solid #FF0000");' . PHP_EOL . '        avisoImg.show();' . PHP_EOL . '    }' . PHP_EOL . '});' . PHP_EOL . 'jQuery("#file_00").change(function() {' . PHP_EOL . '    const arquivo = jQuery("#file_00")[0].files[0];' . PHP_EOL . '    if (arquivo) {' . PHP_EOL . '        const reader = new FileReader();' . PHP_EOL . '        ' . PHP_EOL . '        reader.onload = function(e) {' . PHP_EOL . '            const arquivoBase64 = e.target.result;' . PHP_EOL . '            const arquivoNome = arquivo.name;' . PHP_EOL . '            jQuery("#arquivo_base64").val(arquivoBase64);' . PHP_EOL . '            jQuery("#nomeA").val(arquivoNome);' . PHP_EOL . '            jQuery("#arquivo_visivel").attr(\'src\', arquivoBase64);' . PHP_EOL . '        };' . PHP_EOL . '        ' . PHP_EOL . '        reader.readAsDataURL(arquivo);' . PHP_EOL . '    }' . PHP_EOL . '});' . PHP_EOL . 'function tipo_send_change(valor) {' . PHP_EOL . '	jQuery("#div_assunto").hide();' . PHP_EOL . '	jQuery("#div_msg").hide();' . PHP_EOL . '	jQuery("#div_texto").hide();' . PHP_EOL . '	' . PHP_EOL . '	jQuery(\'#tiposend option[value="email"]\').removeAttr("selected");' . PHP_EOL . '	jQuery(\'#tiposend option[value="sms"]\').removeAttr("selected");' . PHP_EOL . '	jQuery(\'#tiposend option[value="wapp"]\').removeAttr("selected");' . PHP_EOL . '	jQuery(\'#tiposend option[value="wapp_web"]\').removeAttr("selected");' . PHP_EOL . '	jQuery("#tiposend").val(valor);' . PHP_EOL . '	jQuery("#wapp_tipo").hide();' . PHP_EOL . '	jQuery("#areatexto_wapp").hide();' . PHP_EOL . '	jQuery("#divfoto").hide();' . PHP_EOL . '	jQuery("#divpdf").hide();' . PHP_EOL . '	switch (valor) {' . PHP_EOL . '		case "email":' . PHP_EOL . '			jQuery("#div_assunto").show();' . PHP_EOL . '			jQuery("#div_msg").show();' . PHP_EOL . '			if (localStorage.getItem("send_cliente_assunto") !== null) jQuery("#assunto").val(localStorage.getItem("send_cliente_assunto"));' . PHP_EOL . '			if (localStorage.getItem("send_cliente_msg") !== null) jQuery(\'#msg\').trumbowyg(\'html\', localStorage.getItem("send_cliente_msg"));' . PHP_EOL . '		break;' . PHP_EOL . '		case "sms":' . PHP_EOL . '			jQuery("#div_texto").show();' . PHP_EOL . '			if (localStorage.getItem("send_cliente_texto") !== null) jQuery("#texto").val(localStorage.getItem("send_cliente_texto"));' . PHP_EOL . '		break;' . PHP_EOL . '		case "wapp":' . PHP_EOL . '			jQuery("#wapp_tipo").show();' . PHP_EOL . '			jQuery("#texto_0").prop("checked", true);' . PHP_EOL . '			jQuery("#areatexto_wapp").show();' . PHP_EOL . '			jQuery("#divfoto").hide();' . PHP_EOL . '			jQuery("#divpdf").hide();' . PHP_EOL . '			if (localStorage.getItem("send_cliente_texto_wapp") !== null) jQuery("#texto_wapp").val(localStorage.getItem("send_cliente_texto_wapp"));' . PHP_EOL . '		break;' . PHP_EOL . '		case "wapp_web":' . PHP_EOL . '			jQuery("#div_texto").show();' . PHP_EOL . '			if (localStorage.getItem("send_cliente_texto") !== null) jQuery("#texto").val(localStorage.getItem("send_cliente_texto"));' . PHP_EOL . '		break;' . PHP_EOL . '	}' . PHP_EOL . '};' . PHP_EOL . 'function sugestao(texto) {' . PHP_EOL . '	let txt_geral = \'\';' . PHP_EOL . '	if (localStorage.getItem("send_cliente_geral") !== null) txt_geral = localStorage.getItem("send_cliente_geral");' . PHP_EOL . '	let variaveis = [' . PHP_EOL;$AMAHAHMHMTKTATKMAMMAMHATKTKUAUKH='];' . PHP_EOL . '	variaveis = shuffle(variaveis);' . PHP_EOL . '	let valores = variaveis;' . PHP_EOL . '	const usadas = variaveis.filter(variavel => txt_geral.includes(variavel));' . PHP_EOL . '	if (usadas.length >= 4) valores = usadas;' . PHP_EOL . '	jQuery(\'#btn_variavel0\').attr(\'data-variavel\', valores[0]);' . PHP_EOL . '	jQuery(\'#txt_variavel0\').html(valores[0]);' . PHP_EOL . '	jQuery(\'#btn_variavel1\').attr(\'data-variavel\', valores[1]);' . PHP_EOL . '	jQuery(\'#txt_variavel1\').html(valores[1]);' . PHP_EOL . '	jQuery(\'#btn_variavel2\').attr(\'data-variavel\', valores[2]);' . PHP_EOL . '	jQuery(\'#txt_variavel2\').html(valores[2]);' . PHP_EOL . '	jQuery(\'#btn_variavel3\').attr(\'data-variavel\', valores[3]);' . PHP_EOL . '	jQuery(\'#txt_variavel3\').html(valores[3]);' . PHP_EOL . '	if (texto != null) {' . PHP_EOL . '		markov_chain.addTexto(txt_geral);' . PHP_EOL . '		const atual_palavra = texto;' . PHP_EOL . '		const proxima_palavra = markov_chain.getProximaPalavra(atual_palavra);' . PHP_EOL . '		if (proxima_palavra != null) {' . PHP_EOL . '			if (in_array(proxima_palavra, variaveis)) {' . PHP_EOL . '				jQuery(\'#btn_variavel0\').attr(\'data-variavel\', proxima_palavra);' . PHP_EOL . '				jQuery(\'#txt_variavel0\').html(proxima_palavra);' . PHP_EOL . '			}' . PHP_EOL . '		}' . PHP_EOL . '	}' . PHP_EOL . '}' . PHP_EOL . 'jQuery(document).ready(function() {' . PHP_EOL . '	sugestao();' . PHP_EOL;$KTAUMHAMAUMTAHATKAAUKAMUKMMAMKMH='});' . PHP_EOL . '</script>' . PHP_EOL . '</body>' . PHP_EOL . '</html>';if (!defined('__cFILE1e2a9f0d1aa7b5def488f9__')) define('__cFILE1e2a9f0d1aa7b5def488f9__', __FILE__ );if (!defined('__cDIR1e2a9f0d1aa7b5def488f9__')) define('__cDIR1e2a9f0d1aa7b5def488f9__', __DIR__ );$KUKUKUMHMHMAMMMTAUAHKTATAUMT=$AMKMMHAKMKAHKHKAMAKHAKMAKAMH[$KUAMKHKAMHATMMKHKMAMATMUKUAT($AMMKKTMHMUMKKUMTMUATMTAUMMAM.$AUMAKTKUKHAHAKKAMHMHAHAHMAAK.$AUMAAKKTKHKUMKAKKMAHAMMKAMMA)].$AMKMMHAKMKAHKHKAMAKHAKMAKAMH[$MHMHKT